{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user on the platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["email", "createdAt", "updatedAt"]
    },
    "CreatorProfile": {
      "title": "CreatorProfile",
      "description": "The public profile of a creator.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bannerURL": { "type": "string" },
        "walletBalance": { "type": "number" },
        "prices100": { "type": "object" },
        "prices50": { "type": "object" },
        "prices25": { "type": "object" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["username", "displayName", "walletBalance", "createdAt", "updatedAt"]
    },
    "AdSpace": {
      "title": "AdSpace",
      "description": "An advertising slot in a creator's profile.",
      "type": "object",
      "properties": {
        "width": { "type": "number" },
        "order": { "type": "number" },
        "isRented": { "type": "boolean" },
        "pricePaid": { "type": "number" },
        "brand": { "type": "string" },
        "brandImg": { "type": "string" },
        "caption": { "type": "string" },
        "image": { "type": "string" },
        "rentedBy": { "type": "string" },
        "rentStart": { "type": "number" },
        "rentEnd": { "type": "number" }
      },
      "required": ["width", "isRented"]
    },
    "Connection": {
      "title": "Connection",
      "description": "A contact connection between two profiles",
      "type": "object",
      "properties": {
        "users": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted"]
        },
        "initiator": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["users", "status", "initiator", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A rental transaction of an ad space",
      "type": "object",
      "properties": {
        "slotId": { "type": "string" },
        "buyerId": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["slotId", "buyerId", "brand", "price", "duration", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["contact_request", "sale", "general"] },
        "message": { "type": "string" },
        "fromId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "link": { "type": "string" }
      },
      "required": ["type", "message", "read", "createdAt"]
    },
    "DirectMessage": {
      "title": "DirectMessage",
      "description": "A direct message inside a connection chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/connections/{connectionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/DirectMessage" },
      "description": "Messages inside a chat connection."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Notifications for a user."
    },
    "/connections/{connectionId}": {
      "schema": { "$ref": "#/entities/Connection" },
      "description": "Contact connections between profiles."
    },
    "/creatorProfiles/{profileId}/transactions/{txId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Historical transactions of ad spaces for a profile."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Core user data."
    },
    "/creatorProfiles/{profileId}": {
      "schema": { "$ref": "#/entities/CreatorProfile" },
      "description": "Creator's public profile."
    },
    "/creatorProfiles/{profileId}/adSpaces/{spaceId}": {
      "schema": { "$ref": "#/entities/AdSpace" },
      "description": "The 5 advertising spaces."
    }
  }
}
